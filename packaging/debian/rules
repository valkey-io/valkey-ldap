#!/usr/bin/make -f

export DH_VERBOSE = 1
export CARGO_HOME = /usr/local/cargo
export RUSTUP_HOME = /usr/local/rustup
export PATH := $(CARGO_HOME)/bin:$(PATH)

%:
	dh $@

override_dh_auto_build:
	. $(CARGO_HOME)/env && cargo build --release

override_dh_auto_install:
	install -d debian/tmp/usr/lib/valkey/modules
	install -m 755 target/release/libvalkey_ldap.so \
		debian/tmp/usr/lib/valkey/modules/

override_dh_auto_test:
	# Tests require LDAP infrastructure — skip during package build
	true

override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/target/release/
